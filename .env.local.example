# Claude API キー (Claude Vision でゲーム画面スクショを解析)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (ランキング・採用率データの保存先)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhb...
# サーバ専用の書き込み鍵 (RLS をバイパス)。絶対に NEXT_PUBLIC_ を付けないこと
SUPABASE_SERVICE_ROLE_KEY=eyJhb...

# 管理者 API トークン (save/parse エンドポイントの認証)
ADMIN_API_TOKEN=任意の長いランダム文字列

# 管理画面パスワード (ゲームスクショ投入用)
ADMIN_PASSWORD=change-me
